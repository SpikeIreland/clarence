                        },
                        {
                            "name": "max_tokens",
                            "value": 1024
                        },
                        {
                            "name": "messages",
                            "value": "=[{\"role\": \"user\", \"content\": \"Video Title: {{ $json.body.videoTitle }}\\n\\nNotes from recording:\\n{{ $json.body.videoNotes }}\\n\\nTask: Based on the Clarence 'Honest Broker' principles (neutrality, transparency, fairness), generate an optimized YouTube Title and a detailed YouTube description for this video. Format as JSON with keys 'title' and 'description'. Do not use overly salesy language. Emphasize that we are building agreements, not arguments.\"}]"
                        }
                    ]
                },
                "options": {}
