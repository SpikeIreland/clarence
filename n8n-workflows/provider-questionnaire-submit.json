        {
            "parameters": {
                "jsCode": "// ============================================================================\n// PROCESS PROVIDER QUESTIONNAIRE SUBMISSION\n// ============================================================================\n\nconst body = $input.first().json.body || $input.first().json || {};\n\nconsole.log(\"=== PROVIDER QUESTIONNAIRE SUBMISSION V2 ===\");\nconsole.log(\"Received data:\", JSON.stringify(body, null, 2));\n\nconst sessionId = body.sessionId || body.session_id;\nconst providerId = body.providerId || body.provider_id; // ADD THIS\nconst partyType = body.partyType || \"provider\";\nconst answers = body.answers || {};\nconst submittedAt = body.submittedAt || new Date().toISOString();\nconst questionCount = body.questionCount || Object.keys(answers).length;\nconst formVersion = body.formVersion || \"1.0\";\n\nif (!sessionId) {\n  throw new Error(\"Session ID is required\");\n}\n\nconsole.log(\"Session ID:\", sessionId);\nconsole.log(\"Provider ID:\", providerId); // ADD THIS\nconsole.log(\"Answer count:\", Object.keys(answers).length);\n\n// Prepare answers as JSON string for database\nconst answersJson = JSON.stringify(answers);\n\nreturn [\n  {\n    json: {\n      sessionId,\n      providerId, // ADD THIS\n      partyType,\n      answers,\n      answersJson,\n      submittedAt,\n      questionCount,\n      formVersion,\n    },\n  },\n];\n"
            },
            "type": "n8n-nodes-base.code",
