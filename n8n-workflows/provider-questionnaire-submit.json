        {
            "parameters": {
                "jsCode": "// ============================================================================\n// BUILD RESPONSE\n// ============================================================================\n\nconst processData = $('Process Data').first().json;\nconst leverageResult = $input.first().json;\n\nconsole.log('=== QUESTIONNAIRE SUBMISSION COMPLETE ===');\nconsole.log('Leverage calculation result:', JSON.stringify(leverageResult, null, 2));\n\nconst leverageSuccess = leverageResult?.success === true;\nconst leverageData = leverageSuccess ? {\n  customer: leverageResult.leverage?.customer,\n  provider: leverageResult.leverage?.provider,\n  clauseCount: leverageResult.clauses?.count,\n  overallAlignment: leverageResult.clauses?.overallAlignment\n} : null;\n\nreturn [{\n  json: {\n    success: true,\n    message: 'Questionnaire submitted successfully',\n    sessionId: processData.sessionId,\n    questionnaire: {\n      answerCount: Object.keys(processData.answers).length,\n      completedAt: processData.submittedAt\n    },\n    leverageCalculation: leverageSuccess ? 'completed' : 'pending',\n    leverage: leverageData,\n    redirectTo: '/auth/contract-studio?session_id=' + processData.sessionId\n  }\n}];"
