        {
            "parameters": {
                "jsCode": "const body = $input.first().json.body || $input.first().json || {};\n\n// Get session ID and provider ID\nconst sessionId = body.sessionId || body.session_id || \"\";\nconst providerId = body.providerId || body.provider_id || \"\";\n\n// Get questionnaire data and escape single quotes for PostgreSQL\nconst questionnaireData =\n  body.answers || body.questionnaireData || body.questionnaire_data || {};\nconst escapedJson = JSON.stringify(questionnaireData).replace(/'/g, \"''\");\n\nconsole.log(\"=== QUESTIONNAIRE DATA ===\");\nconsole.log(\"Session ID:\", sessionId);\nconsole.log(\"Provider ID:\", providerId);\n\nif (!sessionId) {\n  throw new Error(\"Missing sessionId\");\n}\n\nif (!providerId) {\n  throw new Error(\"Missing providerId\");\n}\n\nreturn [\n  {\n    json: {\n      sessionId: sessionId,\n      providerId: providerId,\n      questionnaireDataEscaped: escapedJson,\n      submittedAt: body.submittedAt || new Date().toISOString(),\n    },\n  },\n];\n"
